:"medium_monique_park_3ef0603a61","mime":"image/png","name":"medium_monique-park.png","path":null,"size":489.49,"width":750,"height":577,"sizeInBytes":489485},"thumbnail":{"ext":".png","url":"https://upbeat-approval-82a9e54c20.media.strapiapp.com/thumbnail_monique_park_3ef0603a61.png","hash":"thumbnail_monique_park_3ef0603a61","mime":"image/png","name":"thumbnail_monique-park.png","path":null,"size":34.86,"width":203,"height":156,"sizeInBytes":34860}},"hash":"monique_park_3ef0603a61","ext":".png","mime":"image/png","size":449.64,"url":"https://upbeat-approval-82a9e54c20.media.strapiapp.com/monique_park_3ef0603a61.png","previewUrl":null,"provider":"strapi-provider-upload-strapi-cloud","provider_metadata":null,"createdAt":"2026-05-05T18:07:09.421Z","updatedAt":"2026-05-05T18:07:09.421Z","publishedAt":"2026-05-05T18:07:09.424Z"}}],"homepage_en":{"id":16,"documentId":"p0apf55g6ywgqaol1big4gf5","manifesto":"We're MDMC—an integrated design & \ndigital strategy agency.\n\nWe help great products find the people \nwho'll love them, and help good, honest \nbusinesses stand out from the noise.","createdAt":"2026-05-09T08:31:49.705Z","updatedAt":"2026-05-09T15:14:09.338Z","publishedAt":"2026-05-09T15:14:10.338Z","locale":"en"},"homepage_ja":{"id":15,"documentId":"p0apf55g6ywgqaol1big4gf5","manifesto":"MDMCは、横浜を拠点とするクリエイティブスタジオです。\n\n「海外と日本をつなぐクリエイティブ」をコンセプトに、\nデザインとデジタル戦略で日本の優れた製品・サービスを\n世界へお届けします。","createdAt":"2026-05-09T08:32:58.960Z","updatedAt":"2026-05-09T14:14:43.206Z","publishedAt":"2026-05-09T14:14:43.249Z","locale":"ja"},"about":{"id":16,"documentId":"xkntakqy4wfduxtp5tcg9qb0","headline":"We're in it for beautiful, honest, useful work.","lede":"MDMC is a small team split across Christchurch, Sydney, and Yokohama. We work with founders, operators, and in-house teams on the design problems that don't fit neatly into a brief — the ones that touch product, brand, and operations at the same time.","kv_1_title":"What we do","kv_1_body":"Branding & identity, digital product design, web & platform design, print & collateral, and the kind of experience design that starts with fixing what's actually broken. We work end-to-end — from diagnosis through to design, build, and beyond.","kv_2_title":"How we work","kv_2_body":"Two-week loops, no layers between you and the people doing the work. We ask more questions upfront than most, because the right solution usually isn't the obvious one.","kv_3_title":"Who we work with","kv_3_body":"Small and medium businesses that have outgrown their current setup, and larger organisations that need an outside eye on how their customers truly experience them. Hospitality, retail, professional services, and anyone whose digital presence no longer reflects the quality of what they do.","kv_4_title":"What we don't do","kv_4_body":"Spec work, or projects without a named decision maker. We also never make something we wouldn't want to use ourselves.","createdAt":"2026-05-10T07:14:51.910Z","updatedAt":"2026-07-08T03:22:08.372Z","publishedAt":"2026-07-08T03:22:08.508Z","hero_image":{"id":21,"documentId":"bza88i452x3d5vjg7iv6zbxv","name":"mdmc-about-us.jpg","alternativeText":null,"caption":null,"focalPoint":null,"width":1920,"height":1280,"formats":{"large":{"ext":".jpg","url":"https://upbeat-approval-82a9e54c20.media.strapiapp.com/large_mdmc_about_us_55479273bd.jpg","hash":"large_mdmc_about_us_55479273bd","mime":"image/jpeg","name":"large_mdmc-about-us.jpg","path":null,"size":126.6,"width":1000,"height":667,"sizeInBytes":126600},"small":{"ext":".jpg","url":"https://upbeat-approval-82a9e54c20.media.strapiapp.com/small_mdmc_about_us_55479273bd.jpg","hash":"small_mdmc_about_us_55479273bd","mime":"image/jpeg","name":"small_mdmc-about-us.jpg","path":null,"size":37.78,"width":500,"height":333,"sizeInBytes":37775},"medium":{"ext":".jpg","url":"https://upbeat-approval-82a9e54c20.media.strapiapp.com/medium_mdmc_about_us_55479273bd.jpg","hash":"medium_mdmc_about_us_55479273bd","mime":"image/jpeg","name":"medium_mdmc-about-u